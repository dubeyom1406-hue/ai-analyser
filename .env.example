# =============================================
# SalesCast AI — Environment Configuration
# =============================================

# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=salescast-secret-key-change-in-production

# Database (PostgreSQL)
# Change these to your actual DB credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=salescast_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Full DB URL (used by SQLAlchemy)
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/salescast_db

# App Settings
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=csv,xlsx,xls
MODEL_SAVE_PATH=backend/models/saved/
